{
  "uid": "importer-r2-hls-v1",
  "title": "Importer: HLS → Cloudflare R2",
  "tags": ["importer", "r2", "hls", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "type": "datasource",
        "name": "DS_PROMETHEUS",
        "label": "Prometheus",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "Prometheus" }
      },
      {
        "type": "query",
        "name": "job",
        "label": "Job",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": { "query": "label_values(up, job)", "refId": "A" },
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "type": "query",
        "name": "instance",
        "label": "Instance",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": { "query": "label_values(up{job=~\"$job\"}, instance)", "refId": "A" },
        "multi": true,
        "includeAll": true,
        "refresh": 1,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "UP",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "max(up{job=~\"$job\",instance=~\"$instance\"})" }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Inflight jobs",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "max(import_inflight_jobs{job=~\"$job\",instance=~\"$instance\"})" }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Time since last success",
      "gridPos": { "x": 8, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - max(import_last_success_timestamp{job=~\"$job\",instance=~\"$instance\"})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 900 },
              { "color": "red", "value": 1800 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Last success timestamp",
      "gridPos": { "x": 16, "y": 0, "w": 8, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        { "refId": "A", "expr": "max(import_last_success_timestamp{job=~\"$job\",instance=~\"$instance\"})" }
      ],
      "fieldConfig": { "defaults": { "unit": "dateTimeAsIso" }, "overrides": [] },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "textMode": "value",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Jobs rate by result",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (result) (rate(import_jobs_total{job=~\"$job\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{result}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "HTTP requests rate by kind+code",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind, code) (rate(import_http_requests_total{job=~\"$job\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{kind}} {{code}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "HTTP duration p50/p95/p99 (by kind)",
      "gridPos": { "x": 0, "y": 11, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum by (le, kind) (rate(import_http_duration_seconds_bucket{job=~\"$job\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{kind}} p50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.95, sum by (le, kind) (rate(import_http_duration_seconds_bucket{job=~\"$job\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{kind}} p95"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum by (le, kind) (rate(import_http_duration_seconds_bucket{job=~\"$job\",instance=~\"$instance\"}[5m])))",
          "legendFormat": "{{kind}} p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "HTTP duration mean (by kind)",
      "gridPos": { "x": 12, "y": 11, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (kind) (rate(import_http_duration_seconds_sum{job=~\"$job\",instance=~\"$instance\"}[5m])) / clamp_min(sum by (kind) (rate(import_http_duration_seconds_count{job=~\"$job\",instance=~\"$instance\"}[5m])), 1)",
          "legendFormat": "{{kind}} mean"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Bytes rate (download vs upload)",
      "gridPos": { "x": 0, "y": 18, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (dir) (rate(import_bytes_total{job=~\"$job\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{dir}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Objects stored to R2 rate (by type)",
      "gridPos": { "x": 12, "y": 18, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (rate(import_objects_total{job=~\"$job\",instance=~\"$instance\"}[5m]))",
          "legendFormat": "{{type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] } }
    },

    {
      "id": 11,
      "type": "timeseries",
      "title": "Current job segments (total vs done)",
      "gridPos": { "x": 0, "y": 25, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "max(import_current_job_segments_total{job=~\"$job\",instance=~\"$instance\"})",
          "legendFormat": "total"
        },
        {
          "refId": "B",
          "expr": "max(import_current_job_segments_done{job=~\"$job\",instance=~\"$instance\"})",
          "legendFormat": "done"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Current job progress (%)",
      "gridPos": { "x": 12, "y": 25, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "targets": [
        {
          "refId": "A",
          "expr": "100 * (max(import_current_job_segments_done{job=~\"$job\",instance=~\"$instance\"}) / clamp_min(max(import_current_job_segments_total{job=~\"$job\",instance=~\"$instance\"}), 1))",
          "legendFormat": "progress"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } }
    }
  ],
  "links": [],
  "fiscalYearStartMonth": 0,
  "liveNow": false
}